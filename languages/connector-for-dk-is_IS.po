#. The sprintf tags represent opening and closing hyperlinks.
#: views/about.php:42
#, php-format
#| msgid ""
#| "%1$sAlda Vigdís%2$s, the lead author of the plugin also provide bespoke "
#| "solutions for WordPress, WooCommerce and other systems, professional "
#| "support and guidance for the use of this plugin as well as security, "
#| "accessibility and perormance audits for your website, and you shouldn't "
#| "hesitate to %4$sreach out to her%2$s if you have any questions. She also "
#| "accepts %3$sdonations on Github Sponsors%2$s."
msgid ""
"%1$sAlda Vigdís%2$s, the lead author of the plugin also provides bespoke "
"solutions for WordPress, WooCommerce and other systems, professional support "
"and guidance for the use of this plugin as well as security, accessibility "
"and perormance audits for your website, and you shouldn't hesitate to "
"%4$sreach out to her%2$s if you have any questions. She also accepts "
"%3$sdonations on Github Sponsors%2$s."
msgstr ""
"%1$sAlda Vigdís%2$s, aðalhöfundur þessarar viðbótar býður uppá sérlausnir "
"fyrir WordPress, WooCommerce og önnur kerfi, faglega aðstoð og handleiðslu "
"við notkun á þessari viðbót og einnig yfirferð á öryggi, aðgengi og afköstum "
"fyrir vefinn þinn og þú ættir ekki að hika við að %4$shafa samband við "
"hana%2$s ef þú ert með einhverjar spurningar. Hún tekur einnig við framlögum "
"í gegn um %3$sGithub Sponsors%2$s."

